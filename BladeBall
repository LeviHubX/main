    -- Helper function for linear interpolation
    local function linearInterpolation(a, b, time_volume)
        return a + (b - a) * time_volume
    end

    -- Curve detection variables
    local lerpRadians = 0
    local lastWarping = tick()
    local previousVelocity = {}
