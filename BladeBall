    -- [3] OYUNCU TAKİP SİSTEMİ
    -- En yakın, hayatta olan oyuncuyu döndürür (Nocturne.PlayerPositionManager)
    local function NocturneGetClosestPlayer()
        local nearestPlayer, minDist = nil, math.huge
        for _, p in next, Players:GetPlayers() do
            if p ~= Player then
                local char = p.Character
                if char and char:IsDescendantOf(Players) then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        local pp = char.PrimaryPart
                        if pp then
                            local dist = Player:DistanceFromCharacter(pp.Position)
                            if dist < minDist then
                                minDist = dist
                                nearestPlayer = p
                            end
                        end
                    end
                end
            end
        end
        return nearestPlayer
    end

    -- Tüm oyuncuların konum tablosunu döndürür (offset +10,10,10 ile)
    local function NocturneGetAllPlayerPositions()
        local positions = {}
        for _, p in next, Players:GetPlayers() do
            local char = p.Character
            if char then
                local pp = char.PrimaryPart
                if pp then
                    positions[p.Name] = pp.Position + Vector3.new(10, 10, 10)
                end
            end
        end
        return positions
    end

