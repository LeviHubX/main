    -- Helper: Create a toggle that tracks visual state for config sync
    local function TrackedToggle(tab, key, config)
        local visualState = config.DefaultValue or false
        local origCallback = config.Callback
        config.Callback = function(Value)
            visualState = Value
            origCallback(Value)
        end
        local toggle = tab:New("Toggle")(config)
        Options[key] = {
            _type = "toggle",
            _toggle = toggle,
            _getVisual = function() return visualState end,
            _click = function()
                if toggle and toggle.Object then
                    pcall(function() firesignal(toggle.Object.MouseButton1Click) end)
                    pcall(function() fireclick(toggle.Object) end)
                end
            end
        }
        return toggle
    end

    -- Helper: Create a slider that tracks value for config sync
    local function TrackedSlider(tab, key, config)
        local currentValue = config.Default or config.Minimum or 0
        local origCallback = config.Callback
        config.Callback = function(Value)
            currentValue = Value
            origCallback(Value)
        end
        local slider = tab:New("Slider")(config)
        Options[key] = {
            _type = "slider",
            _slider = slider,
            _getVisual = function() return currentValue end,
            _setSlider = function(newVal)
                currentValue = newVal
                origCallback(newVal)
                -- Update slider visual via its TextBox
                pcall(function()
                    if slider and slider.Object then
                        local sliderFrame = slider.Object:FindFirstChild("Slider")
                        if sliderFrame then
                            local textBox = sliderFrame:FindFirstChildWhichIsA("TextBox")
                            if textBox then
                                textBox.Text = tostring(newVal)
                                pcall(function() firesignal(textBox.FocusLost, true) end)
                            end
                        end
                    end
                end)
            end
        }
        return slider
    end

