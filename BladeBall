    getgenv().loadConfig = function(name)
        name = name or "Default"
        local path = CONFIG_FOLDER .. name .. ".json"
        
        if not isfile(path) then return false, "File not found" end
        
        local success, config = pcall(function()
            return ConfigLibrary:LoadConfig(path)
        end)
        
        if success and config then
            for k, v in pairs(config) do
                getgenv()[k] = v
            end
            -- Refresh Features
            pcall(function()
                if getgenv().updateESP then getgenv().updateESP() end
                if getgenv().updateAutoParry then getgenv().updateAutoParry() end
                if getgenv().updateAutoSpamParry then getgenv().updateAutoSpamParry() end
                if getgenv().updateAutoSpam then getgenv().updateAutoSpam() end
                if getgenv().updatePlayerSpeed then getgenv().updatePlayerSpeed() end
                if getgenv().updateFOV then getgenv().updateFOV() end
                if getgenv().updateSky then getgenv().updateSky() end
                if getgenv().updateAutoAbility then getgenv().updateAutoAbility() end
                if getgenv().updateAutoSwordBuy then getgenv().updateAutoSwordBuy() end
                if getgenv().updateSemiImmortal then getgenv().updateSemiImmortal() end
                if getgenv().updateHitSounds then getgenv().updateHitSounds() end
                if getgenv().updateNoRender then getgenv().updateNoRender() end
                if getgenv().updateEmotes then getgenv().updateEmotes() end
                
                if getgenv().autoPlay then
                    AutoPlayModule.runThread()
                else
                    AutoPlayModule.finishThread()
                end

                -- Sync UI States: update toggles and sliders
                for key, opt in pairs(Options) do
                    local loadedVal = getgenv()[key]
                    if loadedVal ~= nil and opt._getVisual then
                        if opt._type == "toggle" and opt._click then
                            if loadedVal ~= opt._getVisual() then
                                pcall(function() opt._click() end)
                            end
                        elseif opt._type == "slider" and opt._setSlider then
                            if loadedVal ~= opt._getVisual() then
                                pcall(function() opt._setSlider(loadedVal) end)
                            end
                        end
                    end
                end
            end)
            return true
        end
        return false, config
    end

