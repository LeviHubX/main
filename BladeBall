        local function PetSpawnFollower(id)
            PetClearFollower()

            local success, assets = pcall(function()
                return game:GetObjects("rbxassetid://" .. id)
            end)

            if not success or not assets or #assets == 0 then
                warn("[Pet] Failed to load asset ID: " .. tostring(id))
                return
            end

            local asset = assets[1]
            local handle = nil

            if asset:IsA("Accessory") then
                local h = asset:FindFirstChild("Handle")
                if h then handle = h:Clone() end
            elseif asset:IsA("Model") then
                handle = asset:Clone()
            elseif asset:IsA("BasePart") then
                handle = asset:Clone()
            end

            if not handle then return end

            -- Apply Scaling
            if handle:IsA("Model") then
                handle:ScaleTo(PetCurrentScale)
            else
                PetScaleObject(handle, PetCurrentScale)
            end

            handle.Parent = workspace

            -- Disable collision on all parts
            local allParts = handle:IsA("BasePart") and {handle} or {}
            for _, v in ipairs(handle:GetDescendants()) do
                if v:IsA("BasePart") then
                    table.insert(allParts, v)
                end
            end
            for _, p in ipairs(allParts) do
                p.CanCollide = false
                p.Anchored = false
            end

            local rootPart = handle:IsA("BasePart") and handle or handle.PrimaryPart
            if not rootPart then
                rootPart = handle:FindFirstChildWhichIsA("BasePart", true)
            end
            if not rootPart then return end

            local bp = Instance.new("BodyPosition", rootPart)
            bp.D = 600
            bp.P = 4000
            bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)

            local bg = Instance.new("BodyGyro", rootPart)
            bg.D = 150
            bg.P = 15000
            bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)

