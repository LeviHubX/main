                            end
                        end
                    end)
                    
                    -- Play selected emote if available
                    if getgenv().selectedEmote then
                        getgenv().playEmoteAnimation(getgenv().selectedEmote)
                    end
                end
            end)
        else
            if Animation.track then
                Animation.track:Stop()
                Animation.track:Destroy()
                Animation.track = nil
            end
        end
