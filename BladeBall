    local function spamParryGetBallProperties()
        local ball = parry_helper.FindTargetBall()
        
        if not ball then
            return {
                Velocity = Vector3.zero,
                Direction = Vector3.zero,
                Distance = math.huge,
                Dot = 0
            }
        end
        
        local ballVelocity = Vector3.zero
        if ball:FindFirstChild("zoomies") then
            ballVelocity = ball:FindFirstChild("zoomies").VectorVelocity
        end
        
        local ballDirection = (Player.Character.PrimaryPart.Position - ball.Position).Unit
        local ballDistance = (Player.Character.PrimaryPart.Position - ball.Position).Magnitude
        local ballDot = ballDirection:Dot(ballVelocity.Unit)
        
        return {
            Velocity = ballVelocity,
            Direction = ballDirection,
            Distance = ballDistance,
            Dot = ballDot
        }
    end
    
    local function spamParryService(ballProperties, entityProperties, ping)
        local ball = parry_helper.FindTargetBall()
        local entity = spamParryClosestPlayer()
        
        if not ball then
            return 0
        end
        
        if not entity or not entity.PrimaryPart then
            return 0
        end
        
        local spamAccuracy = 0
        local velocity = ball.AssemblyLinearVelocity
        local speed = velocity.Magnitude
        
        local direction = (Player.Character.PrimaryPart.Position - ball.Position).Unit
        local dot = direction:Dot(velocity.Unit)
        
        local targetPosition = entity.PrimaryPart.Position
        local targetDistance = Player:DistanceFromCharacter(targetPosition)
        
        -- Dynamic distance scaling based on mode
        local baseDist = getgenv().spamParryType == "Blatant" and 85 or 70
        local maximumSpamDistance = ping + math.min(speed / 5.5, baseDist)
        
        if entityProperties.Distance > maximumSpamDistance then
            return spamAccuracy
        end
        
        if ballProperties.Distance > maximumSpamDistance then
            return spamAccuracy
        end
        
        if targetDistance > maximumSpamDistance then
            return spamAccuracy
        end
        
        local maximumSpeed = 5 - math.min(speed / 4, 5)
        local maximumDot = math.clamp(dot, -1, 0) * maximumSpeed
        
        spamAccuracy = maximumSpamDistance - maximumDot
        
        return spamAccuracy
    end
    
