    local ConfigLibrary = (function()
        local cloneref = cloneref or function(...) return ... end
        local HttpService, Lib = cloneref(game:GetService("HttpService")), {}

        Lib.Encode = function(Table) return HttpService:JSONEncode(Table) end
        Lib.Decode = function(Content) return HttpService:JSONDecode(Content) end

        Lib.ConvertValues = function(self, Data, Method)
            local Passed, Stack = {[Data] = true}, {Data}
            repeat
                local Current = table.remove(Stack)
                for Index, Value in next, Current do
                    if type(Value) == "table" and not Passed[Value] then
                        Passed[Value] = true
                        Stack[#Stack + 1] = Value
                    else
                        if Method == "Edit" then
                            if typeof(Value) == "Color3" then
                                Current[Index] = "Color3_("..math.floor(Value.R * 255)..", "..math.floor(Value.G * 255)..", "..math.floor(Value.B * 255)..")"
                            elseif typeof(Value) == "Vector3" or typeof(Value) == "Vector2" or typeof(Value) == "CFrame" then
                                Current[Index] = typeof(Value).."_("..tostring(Value)..")"
                            elseif typeof(Value) == "EnumItem" then
                                Current[Index] = "EnumItem_("..string.match(tostring(Value), "Enum%.(.+)")..")"
                            end
                        else
                            if type(Value) == "string" then
                                local Type, Content = string.match(Value, "(%w+)_%((.+)%)")
                                if Type == "Color3" then
                                    local parts = string.split(Content, ", ")
                                    Current[Index] = Color3.fromRGB(tonumber(parts[1]), tonumber(parts[2]), tonumber(parts[3]))
                                elseif Type == "Vector3" or Type == "Vector2" or Type == "CFrame" then
                                    local parts = string.split(Content, ", ")
                                    for i, v in next, parts do parts[i] = tonumber(v) end
                                    Current[Index] = getfenv()[Type].new(table.unpack(parts))
                                elseif Type == "EnumItem" then
                                    local success, enumObj = pcall(function() return loadstring("return Enum."..Content)() end)
                                    if success then Current[Index] = enumObj end
                                end
                            end
                        end
                    end
                end
            until #Stack == 0
            return Data
        end

        Lib.CloneTable = function(self, Object, Seen)
            if type(Object) ~= "table" then return Object end
            if Seen and Seen[Object] then return Seen[Object] end
            local LocalSeen = Seen or {}
            local Result = setmetatable({}, getmetatable(Object))
            LocalSeen[Object] = Result
            for Index, Value in next, Object do
                Result[self:CloneTable(Index, LocalSeen)] = self:CloneTable(Value, LocalSeen)
            end
            return Result
        end

        Lib.SaveConfig = function(self, Path, Data)
            local Result = self.Encode(self:ConvertValues(self:CloneTable(Data), "Edit"))
            writefile(Path, Result)
        end

        Lib.LoadConfig = function(self, Path)
            return self:ConvertValues(self.Decode(readfile(Path)), "Restore")
        end

        return Lib
    end)()
