                                Options.EmoteDropdown:Set(getgenv().Emotes_Data[1])
                            end
                        end
                    end
                end)
            end
            
            -- Only start emote connection after emotes are loaded
            task.spawn(function()
                if not emotesLoaded then
                    -- Wait for emotes to load
                    local timeout = 0
                    while not emotesLoaded and timeout < 10 do
                        task.wait(0.1)
                        timeout = timeout + 0.1
