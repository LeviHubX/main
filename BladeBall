            if not AutoPlayModule.ball or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                return
            end
            local direction = (
                plr.Character.HumanoidRootPart.Position
                - AutoPlayModule.ball.Position
            ).Unit
