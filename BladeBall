    -- Function to update emotes
    getgenv().updateEmotes = function()
        if emoteConnection then
            emoteConnection:Disconnect()
            emoteConnection = nil
        end
        
        if getgenv().emotesEnabled then
            -- Load emotes if not already loaded
            if not emotesLoaded then
                task.spawn(function()
                    local success = getgenv().loadEmotes()
                    if success then
                        -- Update local reference
                        Emotes_Data = getgenv().Emotes_Data
                        -- Update dropdown if it exists
                        task.wait(0.1) -- Small delay to ensure emotes are loaded
                        if Options and Options.EmoteDropdown and #getgenv().Emotes_Data > 0 then
                            local drop = Options.EmoteDropdown
                            local success = pcall(function() drop:Refresh(getgenv().Emotes_Data) end)
                            if not success then
                                pcall(function() drop:SetValues(getgenv().Emotes_Data) end)
                                pcall(function() drop:SetOptions(getgenv().Emotes_Data) end)
                            end
                            -- Check if selected emote exists in the list
                            local emoteExists = false
                            if getgenv().selectedEmote then
                                for _, emoteName in ipairs(getgenv().Emotes_Data) do
                                    if emoteName == getgenv().selectedEmote then
                                        emoteExists = true
                                        break
                                    end
                                end
                            end
