    local function computeSpeedDivisorMultiplierFromPercent(value)
        value = math.clamp(value or 100, 1, 100)
        return 0.7 + (value - 1) * (0.35 / 99)
    end

    local function computeParryAccuracy(speed, ping, multiplier)
        local cappedSpeedDiff = math.min(math.max(speed - 9.5, 0), 650)
        local speedDivisorBase = 2.4 + cappedSpeedDiff * 0.002
        local speedDivisor = speedDivisorBase * (multiplier or 1)
        if speedDivisor <= 0 then
            return ping
        end
        return ping + math.max(speed / speedDivisor, 9.5)
    end

    local function getAutoParryMultiplier()
        if getgenv().randomAccuracy then
            local minPercent = math.clamp(getgenv().randomAccuracyMin or 30, 1, 100)
            local maxPercent = math.clamp(getgenv().randomAccuracyMax or 80, 1, 100)
            if maxPercent < minPercent then
                minPercent, maxPercent = maxPercent, minPercent
            end
            local randomPercent = math.random(minPercent, maxPercent)
            return computeSpeedDivisorMultiplierFromPercent(randomPercent)
        end
        return computeSpeedDivisorMultiplierFromPercent(getgenv().parryAccuracy or 55)
    end

