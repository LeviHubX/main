    local function spamParryClosestPlayer()
        local maxDistance = math.huge
        local foundEntity = nil
        
        for _, entity in pairs(workspace.Alive:GetChildren()) do
            if tostring(entity) ~= tostring(Player) then
                if entity.PrimaryPart then
                    local distance = Player:DistanceFromCharacter(entity.PrimaryPart.Position)
                    if distance < maxDistance then
                        maxDistance = distance
                        foundEntity = entity
                    end
                end
            end
        end
        
        spamParryClosestEntity = foundEntity
        return foundEntity
    end
    
    local function spamParryGetEntityProperties()
        spamParryClosestPlayer()
        
        if not spamParryClosestEntity then
            return false
        end
        
        local entityVelocity = spamParryClosestEntity.PrimaryPart.Velocity
        local entityDirection = (Player.Character.PrimaryPart.Position - spamParryClosestEntity.PrimaryPart.Position).Unit
        local entityDistance = (Player.Character.PrimaryPart.Position - spamParryClosestEntity.PrimaryPart.Position).Magnitude
        
        return {
