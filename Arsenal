local function IsMelee(tool)
    if not tool:IsA("Tool") then return false end
    local isGun = tool:FindFirstChild("AimPart")
        or tool:FindFirstChild("Ammo")
        or tool:FindFirstChild("FireSound")
        or tool:FindFirstChild("ShootScript")
        or tool:FindFirstChild("GunScript")
    if isGun then return false end
    local handle = tool:FindFirstChild("Handle")
    if handle then return true end
    return false
end

local function ApplySkins()
    local dataFolder = LocalPlayer:FindFirstChild("Data")
    local equippedVal = LocalPlayer:FindFirstChild("Equipped")

    if SkinSettings.SelectedKnife ~= "Default" and dataFolder then
        local meleeData = dataFolder:FindFirstChild("Melee")
        if meleeData and meleeData:IsA("StringValue") then
            if SkinSettings.OriginalMelee == nil then SkinSettings.OriginalMelee = meleeData.Value end
            
            local cleanSkinName = SkinSettings.SelectedKnife
            if string.sub(cleanSkinName, 1, 2) == "v_" or string.sub(cleanSkinName, 1, 2) == "w_" then
                cleanSkinName = string.sub(cleanSkinName, 3)
            elseif string.sub(cleanSkinName, 1, 6) == "Melee_" then
                cleanSkinName = string.sub(cleanSkinName, 7)
            end
            pcall(function() meleeData.Value = cleanSkinName end)
        end
    end

    if SkinSettings.SelectedPlayer ~= "Default" and dataFolder then
        local skinData = dataFolder:FindFirstChild("Skin")
        if skinData and skinData:IsA("StringValue") then
            if SkinSettings.OriginalPlayer == nil then SkinSettings.OriginalPlayer = skinData.Value end
            pcall(function() skinData.Value = SkinSettings.SelectedPlayer end)
        end
    end

    if SkinSettings.SelectedWeapon ~= "Default" and equippedVal then
        if equippedVal:IsA("StringValue") then
            if SkinSettings.OriginalWeapon == nil then SkinSettings.OriginalWeapon = equippedVal.Value end
            pcall(function() equippedVal.Value = SkinSettings.SelectedWeapon end)
        end
    end
end

local function ResetSkins()
    local dataFolder = LocalPlayer:FindFirstChild("Data")
    local equippedVal = LocalPlayer:FindFirstChild("Equipped")
    
    if dataFolder and SkinSettings.OriginalMelee then
        local meleeData = dataFolder:FindFirstChild("Melee")
        if meleeData then pcall(function() meleeData.Value = SkinSettings.OriginalMelee end) end
    end
    
    if dataFolder and SkinSettings.OriginalPlayer then
        local skinData = dataFolder:FindFirstChild("Skin")
        if skinData then pcall(function() skinData.Value = SkinSettings.OriginalPlayer end) end
    end
    
    if equippedVal and SkinSettings.OriginalWeapon then
        if equippedVal:IsA("StringValue") then pcall(function() equippedVal.Value = SkinSettings.OriginalWeapon end) end
    end
end

