local originalSkybox = nil

local function SaveOriginalSkybox()
    if originalSkybox then return end
    local sky = game:GetService("Lighting"):FindFirstChildOfClass("Sky")
    if sky then
        originalSkybox = {
            SkyboxBk = sky.SkyboxBk,
            SkyboxDn = sky.SkyboxDn,
            SkyboxFt = sky.SkyboxFt,
            SkyboxLf = sky.SkyboxLf,
            SkyboxRt = sky.SkyboxRt,
            SkyboxUp = sky.SkyboxUp,
        }
    end
end

local function ApplyCustomSkybox(name)
    local Lighting = game:GetService("Lighting")
    SaveOriginalSkybox()
    if name == "Default" then
        local sky = Lighting:FindFirstChildOfClass("Sky")
        if sky and originalSkybox then
            sky.SkyboxBk = originalSkybox.SkyboxBk
            sky.SkyboxDn = originalSkybox.SkyboxDn
            sky.SkyboxFt = originalSkybox.SkyboxFt
            sky.SkyboxLf = originalSkybox.SkyboxLf
            sky.SkyboxRt = originalSkybox.SkyboxRt
            sky.SkyboxUp = originalSkybox.SkyboxUp
        end
        return
    end
    local ids = SkyboxIds[name]
    if not ids then return end
    local sky = Lighting:FindFirstChildOfClass("Sky")
    if not sky then
        sky = Instance.new("Sky")
        sky.Parent = Lighting
    end
    sky.SkyboxBk = ids[1]
    sky.SkyboxDn = ids[2]
    sky.SkyboxFt = ids[3]
    sky.SkyboxLf = ids[4]
    sky.SkyboxRt = ids[5]
    sky.SkyboxUp = ids[6]
end

local function ApplyChams()
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                for _, part in pairs(tool:GetDescendants()) do
                    if part:IsA("BasePart") then
                        -- Gun Chams
                        if WorldVisualSettings.GunChams then
                            part.Color = WorldVisualSettings.GunChamsColor
                            part.Material = MaterialMap[WorldVisualSettings.GunChamsMaterial] or Enum.Material.Neon
                            part.Transparency = 0
                        end
                    end
                end
            end
        end
        
        -- Arm Chams (first person arms)
        if WorldVisualSettings.ArmChams or WorldVisualSettings.ViewmodelChams then
            local viewmodel = Camera:FindFirstChild("Arms") or Camera:FindFirstChild("ViewModel") or Camera:FindFirstChild("Viewmodel")
            if viewmodel then
                for _, part in pairs(viewmodel:GetDescendants()) do
                    if part:IsA("BasePart") then
                        if WorldVisualSettings.ViewmodelChams then
                            part.Material = MaterialMap[WorldVisualSettings.GunChamsMaterial] or Enum.Material.Neon
                            part.Transparency = 0
                        end
                        if WorldVisualSettings.ArmChams and (part.Name:lower():find("arm") or part.Name:lower():find("hand") or part.Name:lower():find("sleeve")) then
                            part.Color = WorldVisualSettings.ArmChamsColor
                            part.Material = MaterialMap[WorldVisualSettings.GunChamsMaterial] or Enum.Material.Neon
                        end
                    end
                end
            end
        end
    end)
end

