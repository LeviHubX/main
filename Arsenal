local function refreshConfigList()
    configList = {}
    if isfolder(CONFIG_FOLDER) then
        for _, file in next, listfiles(CONFIG_FOLDER) do
            if file:sub(-13) == "_arsenal.json" then
                local name = file:match("([^/^\\]+)_arsenal%.json$")
                if name then table.insert(configList, name) end
            end
        end
    end
    if #configList == 0 then table.insert(configList, "Default") end
    return configList
end

