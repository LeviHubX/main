local Options = {}

local function TrackedToggle(tab, title, config)
    local visualState = config.DefaultValue or false
    local origCallback = config.Callback
    config.Callback = function(Value)
        visualState = Value
        if origCallback then origCallback(Value) end
    end
    local toggle = tab:New("Toggle")(config)
    Options[title] = {
        _type = "toggle",
        _toggle = toggle,
        _getVisual = function() return visualState end,
        _setToggle = function(newVal)
            if visualState == newVal then return end
            pcall(function()
                if toggle and toggle.Object then
                    local signal = true
                    if type(firesignal) == 'function' then
                        pcall(function() firesignal(toggle.Object.MouseButton1Click) end)
                    elseif type(fireclick) == 'function' then
                        pcall(function() fireclick(toggle.Object) end)
                    else
                        visualState = newVal
                        if origCallback then origCallback(newVal) end
                        local frame = toggle.Object:FindFirstChild("Frame") or toggle.Object:FindFirstChildWhichIsA("Frame", true)
                        if frame then
                            if newVal then
                                frame.BackgroundColor3 = Color3.fromRGB(0, 255, 128)
                            else
                                frame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                            end
                        end
                    end
                end
            end)
        end
    }
    return toggle
end

local function TrackedSlider(tab, title, config)
    local currentValue = config.Default or config.Minimum or 0
    local origCallback = config.Callback
    config.Callback = function(Value)
        currentValue = Value
        if origCallback then origCallback(Value) end
    end
    local slider = tab:New("Slider")(config)
    Options[title] = {
        _type = "slider",
        _slider = slider,
        _getVisual = function() return currentValue end,
        _setSlider = function(newVal)
            if currentValue == newVal then return end
            currentValue = newVal
            if origCallback then origCallback(newVal) end
            pcall(function()
                if slider and slider.Object then
                    local sliderFrame = slider.Object:FindFirstChild("Slider")
                    if sliderFrame then
                        local textBox = sliderFrame:FindFirstChildWhichIsA("TextBox")
                        if textBox then
                            textBox.Text = tostring(newVal)
                            pcall(function() firesignal(textBox.FocusLost, true) end)
                        end
                    end
                end
            end)
        end
    }
    return slider
end

