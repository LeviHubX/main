-- ==================== HIGHLIGHT ESP SYSTEM ====================
local espHighlights = {}
local espConnections = {}

local function IsESPEnemy(plr)
    if not plr or plr == LocalPlayer then return false end
    if not plr.Character then return false end
    local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    if ScriptSettings.TeamCheck then
        local sameTeam = false
        pcall(function()
            if plr.TeamColor == LocalPlayer.TeamColor then
                sameTeam = true
            end
            if plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then
                sameTeam = true
            end
        end)
        if sameTeam then return false end
    end
    return true
end

local function rainbowColor()
    local t = tick() * 3
    return Color3.new(
        (math.sin(t) + 1) / 2,
        (math.sin(t + 2) + 1) / 2,
        (math.sin(t + 4) + 1) / 2
    )
end

local function ApplyHighlight(player)
    if player == LocalPlayer then return end
    pcall(function()
        -- Remove old highlight if exists
        if espHighlights[player] then
            pcall(function() espHighlights[player]:Destroy() end)
            espHighlights[player] = nil
        end

        local character = player.Character
        if not character then return end

        -- Remove any existing LeviESP highlights
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Highlight") and child.Name == "LeviESP" then
                child:Destroy()
            end
        end

        local highlight = Instance.new("Highlight")
        highlight.Name = "LeviESP"
        highlight.FillColor = ScriptSettings.FillColor
        highlight.OutlineColor = ScriptSettings.OutlineColor
        highlight.FillTransparency = ScriptSettings.FillTransparency
        highlight.OutlineTransparency = ScriptSettings.OutlineTransparency
        highlight.Adornee = character
        highlight.Enabled = ScriptSettings.Enabled
        highlight.Parent = character

        espHighlights[player] = highlight
    end)
end

local function RemoveHighlight(player)
    pcall(function()
        if espHighlights[player] then
            espHighlights[player]:Destroy()
            espHighlights[player] = nil
        end
    end)
    if espConnections[player] then
        pcall(function() espConnections[player]:Disconnect() end)
        espConnections[player] = nil
    end
end

local function SetupPlayer(player)
    if player == LocalPlayer then return end
    ApplyHighlight(player)
    -- Reconnect on respawn
    if espConnections[player] then
        pcall(function() espConnections[player]:Disconnect() end)
    end
    espConnections[player] = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        ApplyHighlight(player)
    end)
end

function UpdateHighlightESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if ScriptSettings.Enabled then
                if not espHighlights[player] then
                    SetupPlayer(player)
                end
            else
                pcall(function()
                    if espHighlights[player] then
                        espHighlights[player].Enabled = false
                    end
                end)
            end
        end
    end
end

-- Initialize ESP for existing players
for _, player in ipairs(Players:GetPlayers()) do
    SetupPlayer(player)
end

Players.PlayerAdded:Connect(function(player)
    task.wait(1)
    SetupPlayer(player)
end)

Players.PlayerRemoving:Connect(function(player)
    RemoveHighlight(player)
end)

-- ESP update loop: rainbow color + enable/disable
RunService.RenderStepped:Connect(function()
    pcall(function()
        if not ScriptSettings.Enabled then
            for player, hl in pairs(espHighlights) do
                pcall(function() hl.Enabled = false end)
            end
            return
        end

        local rbColor = rainbowColor()

        for player, hl in pairs(espHighlights) do
            pcall(function()
                if not player or not player.Parent then return end

                -- Reattach if highlight lost its parent
                if not hl.Parent and player.Character then
                    hl.Adornee = player.Character
                    hl.Parent = player.Character
                end

                if IsESPEnemy(player) then
                    hl.Enabled = true
                    hl.FillTransparency = ScriptSettings.FillTransparency
                    hl.OutlineTransparency = ScriptSettings.OutlineTransparency

                    if ScriptSettings.RainbowESP then
                        hl.OutlineColor = rbColor
                        hl.FillColor = rbColor
                    else
                        hl.OutlineColor = ScriptSettings.OutlineColor
                        hl.FillColor = ScriptSettings.FillColor
                    end
                else
                    hl.Enabled = false
                end
            end)
        end
    end)
end)
