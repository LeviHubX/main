-- Arsenal-specific enemy check using TeamColor
local function IsEnemy(plr)
    if plr == LocalPlayer then return false end
    if not plr.Character then return false end
    
    -- TeamColor-based check (Arsenal uses TeamColor for teams)
    if CombatSettings.AimbotTeamCheck and not CheckFFA() then
        if plr.TeamColor == LocalPlayer.TeamColor then return false end
        if plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then return false end
    end
    
    local humanoid = plr.Character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    if humanoid.Health <= 0 then return false end
    
    -- Dead state check (pcall to handle edge cases)
    local isDead = false
    pcall(function()
        if humanoid:GetState() == Enum.HumanoidStateType.Dead then
            isDead = true
        end
    end)
    if isDead then return false end
    
    -- Underground / fallen off map check
    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    if hrp.Position.Y < -50 then return false end
    
    return true
end

-- Wall check (raycast visibility)
local function IsVisible(targetPart)
    if not CombatSettings.WallCheck then return true end
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    local result = workspace:Raycast(origin, direction, rayParams)
    if result then
        if result.Instance and result.Instance:IsDescendantOf(targetPart.Parent) then
            return true
        end
        return false
    end
    return true
end

-- Get closest enemy head/part for aimbot (Camera Lerp method)
local function GetClosestEnemyPart()
    local closest = nil
    local closestDist = CombatSettings.FOVRadius
    
    for _, plr in pairs(Players:GetPlayers()) do
        if IsEnemy(plr) and plr.Character then
            local targetPart = plr.Character:FindFirstChild(CombatSettings.HitPart)
            if not targetPart then
                targetPart = plr.Character:FindFirstChild("Head")
            end
            if not targetPart then continue end
            
            -- Y difference check (skip underground/glitched players)
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local yDiff = math.abs(LocalPlayer.Character.HumanoidRootPart.Position.Y - targetPart.Position.Y)
                if yDiff > 100 then continue end
            end
            
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local delta = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if delta < closestDist then
                    -- Wall check
                    if IsVisible(targetPart) then
                        closest = targetPart
                        closestDist = delta
                    end
                end
            end
        end
    end
    return closest
end



-- Golden Knife Teleport function
local function DoGoldenKnifeTeleport()
    pcall(function()
        local goldenKnife = nil
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name == "GoldenKnife" or obj.Name == "Golden Knife" or (obj.Parent and obj.Parent.Name == "GoldenKnife")) then
                goldenKnife = obj
                break
            end
        end
        -- Also check for golden knife tool on ground
        if not goldenKnife then
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Tool") and (obj.Name:lower():find("golden") or obj.Name:lower():find("gold knife")) then
                    local handle = obj:FindFirstChild("Handle")
