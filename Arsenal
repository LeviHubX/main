local saveConfig = function(name)
    name = name or "Default"
    local path = CONFIG_FOLDER .. name .. "_arsenal.json"
    local configData = {
        ScriptSettings = ScriptSettings,
        CombatSettings = CombatSettings,
        SkinSettings = SkinSettings,
        GunModSettings = GunModSettings,
        WorldVisualSettings = WorldVisualSettings
    }
    pcall(function() writefile(path, ConfigLibrary.Encode(configData)) end)
    return true
end

local loadConfig = function(name)
    name = name or "Default"
    local path = CONFIG_FOLDER .. name .. "_arsenal.json"
    if not isfile(path) then return false end
    local success, conf = pcall(function() return ConfigLibrary.Decode(readfile(path)) end)
    if success and conf then
        for k,v in pairs(conf.ScriptSettings or {}) do ScriptSettings[k] = v end
        for k,v in pairs(conf.CombatSettings or {}) do CombatSettings[k] = v end
        for k,v in pairs(conf.SkinSettings or {}) do SkinSettings[k] = v end
        for k,v in pairs(conf.GunModSettings or {}) do GunModSettings[k] = v end
        for k,v in pairs(conf.WorldVisualSettings or {}) do WorldVisualSettings[k] = v end
        
        -- Sync UI States
        for key, opt in pairs(Options) do
            local loadedVal = nil
            -- search through our settings tables
            for _, tName in ipairs({ScriptSettings, CombatSettings, SkinSettings, GunModSettings, WorldVisualSettings, Config}) do
                if type(tName) == "table" then
                    -- heuristic match
                    for k,v in pairs(tName) do
                        if k == key:gsub("%s+", "") or string.find(key:lower(), k:lower()) or string.find(k:lower(), key:lower()) then
                            loadedVal = v
                            break
                        end
                    end
                end
                if loadedVal ~= nil then break end
            end

            if loadedVal ~= nil and opt._getVisual then
                if opt._type == "toggle" and opt._setToggle then
                    if loadedVal ~= opt._getVisual() then
                        pcall(function() opt._setToggle(loadedVal) end)
                    end
                elseif opt._type == "slider" and opt._setSlider then
                    if loadedVal ~= opt._getVisual() then
                        pcall(function() opt._setSlider(loadedVal) end)
                    end
                elseif opt._type == "dropdown" and opt._setDropdown then
                    if loadedVal ~= opt._getVisual() then
                        pcall(function() opt._setDropdown(loadedVal) end)
                    end
                elseif opt._type == "keybind" and opt._setKeybind then
                    if loadedVal ~= opt._getVisual() then
                        pcall(function() opt._setKeybind(loadedVal) end)
                    end
                end
            end
        end

        return true
    end
    return false
end
