        if goldenKnife and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = goldenKnife.CFrame + Vector3.new(0, 3, 0)
        end
    end)
end

-- Kill All System (ported from main.lua)
local killAllThread = nil
local isFFA = false
local lastFFACheck = 0

local function CheckFFA()
    local now = tick()
    if now - lastFFACheck < 1 then return isFFA end
    lastFFACheck = now
    local allPlayers = Players:GetPlayers()
    if #allPlayers <= 1 then isFFA = false return isFFA end
    local firstTeam = nil
    local allSame = false
    for _, p in ipairs(allPlayers) do
        if p.Team then
            if not allSame then
                firstTeam = p.Team
                allSame = true
            elseif p.Team ~= firstTeam then
                isFFA = false
                return isFFA
            end
        end
    end
    if allSame then isFFA = true else isFFA = false end
    return isFFA
end

local function IsKillAllEnemy(plr)
    if plr == LocalPlayer then return false end
    if not CheckFFA() then
        if plr.Team == LocalPlayer.Team then return false end
        if not plr.Team then return false end
        if plr.Team.Name == "TGC" then return false end
    end
    local char = plr.Character
    if not char then return false end
    if not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Head") then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if char.HumanoidRootPart.Position.Y < -100 then return false end
    -- Lobby/spawn area check
    if (char.HumanoidRootPart.Position - Vector3.new(0.9, -400, 2.5)).Magnitude < 50 then return false end
    -- Distance check
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        if (char.HumanoidRootPart.Position - myChar.HumanoidRootPart.Position).Magnitude > 300 then return false end
    end
    return true
end

local function StartKillAll()
    if killAllThread then return end
    CombatSettings.KillAllEnabled = true
    killAllThread = task.spawn(function()
        while CombatSettings.KillAllEnabled do
            for _, plr in ipairs(Players:GetPlayers()) do
                if not CombatSettings.KillAllEnabled then break end
                if IsKillAllEnemy(plr) then
                    local enemyChar = plr.Character
                    local myChar = LocalPlayer.Character
                    -- Teleport and stay on enemy until dead
                    while CombatSettings.KillAllEnabled do
                        if not IsKillAllEnemy(plr) then break end
                        local hrp = enemyChar.HumanoidRootPart
                        local head = enemyChar.Head
                        myChar.HumanoidRootPart.CFrame = CFrame.new(hrp.Position - hrp.CFrame.LookVector * 3, head.Position)
                        Camera.CFrame = CFrame.new(Camera.CFrame.Position, head.Position)
                        task.wait()
                    end
                    -- Attack if still valid
                    if IsKillAllEnemy(plr) then
                        local tool = myChar:FindFirstChildOfClass("Tool")
                        local fireEvent = ReplicatedStorage:FindFirstChild("FireEvent")
                        if tool and fireEvent then
                            fireEvent:FireServer()
                        elseif tool then
                            tool:Activate()
                        end
                    end
                end
            end
            task.wait()
        end
    end)
end

local function StopKillAll()
    CombatSettings.KillAllEnabled = false
    if killAllThread then
        task.cancel(killAllThread)
        killAllThread = nil
    end
end

-- Silent Aim running state
local silentAimRunning = false
local silentAimThread = nil

local function StartSilentAim()
    if silentAimRunning then return end
    silentAimRunning = true
    silentAimThread = coroutine.create(function()
        while silentAimRunning do
            pcall(function()
                for _, v in pairs(Players:GetPlayers()) do
                    if v.Name ~= LocalPlayer.Name and v.Character then
                        pcall(function()
                            if v.Character:FindFirstChild("RightUpperLeg") then
                                v.Character.RightUpperLeg.CanCollide = false
                                v.Character.RightUpperLeg.Transparency = 10
                                v.Character.RightUpperLeg.Size = Vector3.new(13, 13, 13)
                            end
                            if v.Character:FindFirstChild("LeftUpperLeg") then
                                v.Character.LeftUpperLeg.CanCollide = false
                                v.Character.LeftUpperLeg.Transparency = 10
                                v.Character.LeftUpperLeg.Size = Vector3.new(13, 13, 13)
                            end
                            if v.Character:FindFirstChild("HeadHB") then
                                v.Character.HeadHB.CanCollide = false
                                v.Character.HeadHB.Transparency = 10
                                v.Character.HeadHB.Size = Vector3.new(13, 13, 13)
                            end
                            if v.Character:FindFirstChild("HumanoidRootPart") then
                                v.Character.HumanoidRootPart.CanCollide = false
                                v.Character.HumanoidRootPart.Transparency = 10
                                v.Character.HumanoidRootPart.Size = Vector3.new(13, 13, 13)
                            end
                        end)
                    end
                end
            end)
            task.wait(1)
        end
    end)
    coroutine.resume(silentAimThread)
end

local function StopSilentAim()
    silentAimRunning = false
    -- Reset hitbox sizes
    pcall(function()
        for _, v in pairs(Players:GetPlayers()) do
            if v.Name ~= LocalPlayer.Name and v.Character then
                pcall(function()
                    if v.Character:FindFirstChild("RightUpperLeg") then
                        v.Character.RightUpperLeg.Size = Vector3.new(1, 1.5, 1)
                        v.Character.RightUpperLeg.Transparency = 0
                    end
                    if v.Character:FindFirstChild("LeftUpperLeg") then
                        v.Character.LeftUpperLeg.Size = Vector3.new(1, 1.5, 1)
                        v.Character.LeftUpperLeg.Transparency = 0
                    end
                    if v.Character:FindFirstChild("HeadHB") then
                        v.Character.HeadHB.Size = Vector3.new(1.2, 1.2, 1.2)
                        v.Character.HeadHB.Transparency = 1
                    end
                    if v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                        v.Character.HumanoidRootPart.Transparency = 1
                    end
                end)
            end
        end
    end)
end

